{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RPG Maker MV Tilesets",
  "description": "Schema for Tilesets.json - a positional array where index 0 is null",
  "type": "array",
  "items": {
    "oneOf": [
      { "type": "null" },
      { "$ref": "#/$defs/tilesetEntry" }
    ]
  },
  "$defs": {
    "tilesetEntry": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "mode": { "type": "integer" },
        "tilesetNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "flags": { "type": "array" }
      }
    }
  }
}
