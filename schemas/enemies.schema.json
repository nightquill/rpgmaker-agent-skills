{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RPG Maker MV Enemies",
  "description": "Schema for Enemies.json - a positional array where index 0 is null",
  "type": "array",
  "items": {
    "oneOf": [
      { "type": "null" },
      { "$ref": "#/$defs/enemyEntry" }
    ]
  },
  "$defs": {
    "enemyEntry": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "battlerName": { "type": "string" },
        "battlerHue": { "type": "integer" },
        "params": {
          "type": "array",
          "items": { "type": "number" }
        },
        "exp": { "type": "integer" },
        "gold": { "type": "integer" },
        "dropItems": { "type": "array" },
        "actions": { "type": "array" },
        "traits": { "type": "array" },
        "note": { "type": "string" }
      }
    }
  }
}
