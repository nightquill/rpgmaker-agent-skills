{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RPG Maker MV CommonEvents",
  "description": "Schema for CommonEvents.json - a positional array where index 0 is null",
  "type": "array",
  "items": {
    "oneOf": [
      { "type": "null" },
      { "$ref": "#/$defs/commonEventEntry" }
    ]
  },
  "$defs": {
    "commonEventEntry": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "trigger": { "type": "integer" },
        "switchId": { "type": "integer" },
        "list": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "code": { "type": "integer" },
              "indent": { "type": "integer" },
              "parameters": { "type": "array" }
            }
          }
        }
      }
    }
  }
}
